# Doppelgänger runtime — ONE process: dispatcher + scheduler. No OS cron.
# Installed as a systemd *user* unit by install.sh (claude/gws auth lives in the user's home).
[Unit]
Description=Doppelganger runtime (dispatcher + scheduler)
After=network-online.target

[Service]
Type=simple
WorkingDirectory={{REPO_DIR}}/doppelganger
ExecStart={{NODE_BIN}} src/index.ts
Environment=DOPPELGANGER_HOME={{DOPPELGANGER_HOME}}
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
